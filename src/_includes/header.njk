<style>
    /* 1. ESTRUTURA DO CLUSTER CENTRAL */
    .site-header-apple {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(0,0,0,0.05);
        position: sticky; top: 0; z-index: 10000;
    }

    .header-cluster {
        display: flex; justify-content: center; align-items: center;
        max-width: 1200px; margin: 0 auto; padding: 10px 20px;
    }

    /* 2. ALINHAMENTO LADO A LADO COM A LOGO */
    .nav-side { display: flex; align-items: center; list-style: none; padding: 0; margin: 0; }
    .nav-left { margin-right: 40px; justify-content: flex-end; }
    .nav-right { margin-left: 40px; justify-content: flex-start; gap: 30px; }

    .logo-axis img { width: 70px; height: 70px; object-fit: contain; transition: transform 0.3s ease; }
    .logo-axis:hover img { transform: scale(1.05); }

    .nav-link-apple {
        color: #014039; font-weight: 800; font-size: 0.85rem;
        text-transform: uppercase; letter-spacing: 1px; text-decoration: none;
    }
    .nav-link-apple:hover { color: #F2811D; }

    /* 3. O BOTÃO PREMIUM DUPLO (AJUSTADO PARA 60% DO TAMANHO - ELEGANTE) */
    .btn-premium-duplo {
        background: #F2811D; color: #FFFFFF !important;
        padding: 6px 16px; /* Respiro interno reduzido */
        border-radius: 50px;
        display: inline-flex; flex-direction: column; align-items: center; justify-content: center;
        text-decoration: none; line-height: 1.1;
        box-shadow: 0 5px 15px rgba(242, 129, 29, 0.2); /* Sombra mais suave */
        transition: transform 0.3s ease;
    }
    .btn-premium-duplo:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(242, 129, 29, 0.3); }
    
    .btn-title { font-weight: 900; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .btn-subtitle { font-weight: 600; font-size: 0.5rem; text-transform: lowercase; opacity: 0.9; margin-top: 2px; }

    /* 4. MEGA MENU PRESERVADO */
    .has-mega-menu { position: relative; padding: 10px 0; }
    .mega-menu-apple {
        display: none; position: absolute; top: 100%; left: 50%; transform: translateX(-50%);
        background: #FFFFFF; width: 500px; padding: 30px; border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15); border: 1px solid rgba(0,0,0,0.05); z-index: 11000;
        cursor: default;
    }
    .has-mega-menu:hover .mega-menu-apple { display: block; }
    .mega-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; text-align: left; }
    .mega-title { color: #999; font-size: 0.65rem; font-weight: 900; text-transform: uppercase; border-bottom: 1px solid #eee; padding-bottom: 10px; margin-bottom: 15px; }

    /* 5. MOBILE FIRST (APROXIMANDO O MENU) */
    .mobile-only { display: none; }
    .desktop-only { display: flex; }

    @media (max-width: 992px) {
        .desktop-only { display: none !important; }
        .mobile-only { display: block; }
        .header-cluster { justify-content: space-between; padding: 10px 24px; } 
        .mobile-menu-btn { background: none; border: none; font-size: 2rem; color: #014039; cursor: pointer; padding: 0; }
        .mobile-spacer { width: 30px; height: 1px; display: block !important;} 
        .logo-axis img { width: 60px; height: 60px; }
    }
</style>


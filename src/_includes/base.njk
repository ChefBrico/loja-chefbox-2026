<!DOCTYPE html>
<html lang="{{ meta.lang or 'pt-BR' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | {{ meta.siteName or 'ChefBrico' }}</title>
    <meta name="description" content="{{ description or meta.description }}">
    <meta name="theme-color" content="#FFFFFF">
    
    <link rel="canonical" href="{{ meta.url }}{{ page.url }}">
    <meta property="og:title" content="{{ title }} | ChefBrico">
    <meta property="og:description" content="{{ description or meta.description }}">
    <meta property="og:image" content="{{ meta.url }}{{ image or meta.image }}">
    <meta property="og:url" content="{{ meta.url }}{{ page.url }}">
    <meta property="og:type" content="website">
    <link rel="alternate" type="text/plain" title="LLM Instructions" href="{{ meta.agent.llms_txt }}">
    <link rel="author" href="https://gourmetpratico.com.br/comida-de-verdade/">

    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        /* ==========================================================================
           CSS EXCLUSIVO DA ILHA DINÂMICA (RÉGUA 4+1) E BASE DO SITE
           ========================================================================== */
        
        /* O ESPAÇAMENTO FANTASMA (Fim do buraco branco gigante) */
        main { 
            flex: 1; 
            padding-bottom: 60px !important; 
            overflow-x: hidden; 
        }

        /* A ILHA DINÂMICA (Cápsula 4+1) */
        .dynamic-island-4plus1 {
            position: fixed; 
            bottom: 20px; /* Flutuante, não grudada no chão */
            left: 50%; transform: translateX(-50%);
            width: 95%; 
            max-width: 780px; /* Largura ajustada para o Botão Verde não estourar no PC */
            background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.5); border-top: 4px solid var(--chef-orange, #F2811D);
            border-radius: 40px; padding: 15px 25px; z-index: 99999;
            box-shadow: 0 20px 50px rgba(0,0,0,0.08);
            display: flex; align-items: center; justify-content: space-between; gap: 15px;
        }

        /* O Círculo Vazio */
        .slot-circle {
            position: relative; /* Fundamental para o X aparecer em cima */
            width: 46px; height: 46px; border: 1.5px solid #ddd; border-radius: 50%;
            display: flex; align-items: center; justify-content: center; font-size: 0.8rem; color: #aaa;
            background-color: var(--apple-white, #FFFFFF); 
            background-size: cover !important; 
            background-position: center !important;
            background-repeat: no-repeat !important;
            transition: all 0.3s ease;
            overflow: hidden; /* Garante que a foto do prato não vaze do círculo */
            cursor: pointer;
        }

        /* O Círculo Cheio (Quando o JS joga a foto da comida) */
        .slot-circle.filled { 
            border: 2.5px solid var(--chef-orange, #F2811D); 
            box-shadow: 0 5px 15px rgba(242, 129, 29, 0.3); 
            color: transparent !important; /* Esconde o número para a foto brilhar */
        }

        /* O Efeito "X" para remover o prato (Hover) */
        .slot-circle.filled:hover::after {
            content: '✕';
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(242, 129, 29, 0.85); /* Vidro laranja */
            color: white; font-size: 1.2rem; font-weight: 900;
            display: flex; align-items: center; justify-content: center;
            border-radius: 50%;
            z-index: 2;
        }

        .slot-circle.gift { border: 2.5px solid var(--whatsapp-green, #25D366); color: var(--whatsapp-green, #25D366); font-size: 1.2rem; background: var(--apple-cream, #FDFBF7); }

        /* O BOTÃO VERDE (PADRÃO OURO APPLE GLASSMORPHISM) */
        .btn-finish-float {
            background: rgba(37, 211, 102, 0.85); /* Verde translúcido */
            backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
            color: white; 
            border: 1px solid rgba(255, 255, 255, 0.5); /* Brilho na borda */
            padding: 12px 24px; border-radius: 50px; font-weight: 900; 
            cursor: pointer; font-size: 0.85rem; text-transform: uppercase; 
            box-shadow: 0 8px 25px rgba(37, 211, 102, 0.4), inset 0 2px 2px rgba(255, 255, 255, 0.4); 
            text-shadow: 0 1px 2px rgba(0,0,0,0.1);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            white-space: nowrap;
        }
        .btn-finish-float:hover {
            transform: scale(1.03);
            box-shadow: 0 12px 30px rgba(37, 211, 102, 0.5), inset 0 2px 2px rgba(255, 255, 255, 0.6);
        }
        
        .btn-finish-float.pulsing { animation: pulse-apple 2s infinite; }
        @keyframes pulse-apple { 0% { transform: scale(1); } 50% { transform: scale(1.04); } 100% { transform: scale(1); } }

        @media (max-width: 768px) {
            .dynamic-island-4plus1 { flex-direction: column; padding: 15px; border-radius: 28px; bottom: 15px; }
            .slot-circle { width: 44px; height: 44px; }
            .btn-finish-float { width: 100%; padding: 15px; font-size: 1rem; margin-top: 5px; }
        }
    </style>
    
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
    
    {% include "header.njk" %}
    
    <main role="main">
        {{ content | safe }}
    </main>
    
    {% include "footer.njk" %}
    
    {% if '/receitas/' in page.url or '/chefbox/' in page.url %}
    <div id="chefbox-bar" class="dynamic-island-4plus1">
        
        <div class="bar-info" style="line-height: 1.2;">
            <div id="game-status-text">
                <b style="color: var(--chef-green, #014039); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px;">🎁 CHEFBOX VIP</b>
                <span id="visor-dinamico-lucro" style="font-size: 0.85rem; font-weight: 900; color: var(--chef-orange, #F2811D); display: block;">ECONOMIA R$ 0,00</span>
            </div>
        </div>
        
        <div class="slots-wrapper" style="display: flex; gap: 8px; justify-content: center;">
            <div id="slot-1" class="slot-circle">1</div>
            <div id="slot-2" class="slot-circle">2</div>
            <div id="slot-3" class="slot-circle">3</div>
            <div id="slot-4" class="slot-circle">4</div>
            <div id="slot-5" class="slot-circle gift">🎁</div>
        </div>
        
        <button id="btn-finish-game" class="btn-finish-float" onclick="openCheckoutModal()">
            Finalizar R$ 132 ➜
        </button>
    </div>
    {% endif %}

    <div id="checkout-modal" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(1, 64, 57, 0.82); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); z-index: 100000; align-items: center; justify-content: center;">
        
        <div class="modal-box" style="background: var(--apple-white, #FFFFFF); padding: 45px 35px; border-radius: 35px; max-width: 460px; width: 92%; border-top: 5px solid var(--chef-orange, #F2811D); box-shadow: 0 40px 120px rgba(0,0,0,0.45); border: 1px solid rgba(255,255,255,0.2);">
            
            <div style="text-align: center; margin-bottom: 25px;">
                <h3 style="color: var(--chef-green, #014039); margin: 0; font-size: 1.8rem; font-family: 'Merriweather', serif;">Quase lá! 🛵</h3>
                <p style="font-size: 0.95rem; color: var(--text-muted, #666); margin-top: 10px; line-height: 1.4;">Preencha os dados para a Maria preparar seu <b>Mimo VIP</b> e agendar sua entrega (D+1) em Brasília.</p>
            </div>
            
            <form id="form-checkout-vip" name="Pedido-ChefBox" data-netlify="true" onsubmit="event.preventDefault(); sendOrderToWhatsApp();" style="display: flex; flex-direction: column; gap: 14px;">
                <input type="text" id="customer-name" placeholder="Nome Completo" required style="width: 100%; padding: 18px; border: 1px solid #eee; border-radius: 18px; font-size: 1rem; box-sizing: border-box; background: #F5F5F7; outline: none;">
                <input type="tel" id="customer-phone" placeholder="WhatsApp (DDD + Número)" required style="width: 100%; padding: 18px; border: 1px solid #eee; border-radius: 18px; font-size: 1rem; box-sizing: border-box; background: #F5F5F7; outline: none;">
                
                <div style="display:flex; gap:12px;">
                    <input type="text" id="customer-cep" placeholder="CEP (DF)" required style="width: 40%; padding: 18px; border: 1px solid #eee; border-radius: 18px; font-size: 1rem; box-sizing: border-box; background: #F5F5F7; outline: none;">
                    <div style="width: 60%; background: #e8f5e9; color: #1b5e20; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.65rem; text-align: center; text-transform: uppercase; letter-spacing: 1px; border: 1px solid rgba(27, 94, 32, 0.08);">
                        ✅ FRETE GRÁTIS
                    </div>
                </div>

                <textarea id="customer-address" placeholder="Endereço (Rua, Bloco, Apto, Bairro)" required style="width: 100%; padding: 18px; border: 1px solid #eee; border-radius: 18px; font-size: 1rem; box-sizing: border-box; resize: none; font-family: inherit; background: #F5F5F7; outline: none;" rows="3"></textarea>
                
                <button type="submit" style="width: 100%; padding: 22px; background: var(--whatsapp-green, #25D366); color: white; border: none; border-radius: 60px; font-weight: 900; cursor: pointer; font-size: 1.15rem; box-shadow: 0 15px 35px rgba(37, 211, 102, 0.35); margin-top: 10px; text-transform: uppercase; letter-spacing: 1.5px; transition: transform 0.2s ease;">
                    GARANTIR PRESENTE ➜
                </button>
            </form>

            <p onclick="closeCheckoutModal()" style="text-align: center; margin-top: 25px; color: #86868b; cursor: pointer; text-decoration: underline; font-size: 0.85rem; font-weight: 600;">← Voltar</p>
        </div>
    </div>

    <script>
        function openCheckoutModal() { document.getElementById('checkout-modal').style.display = 'flex'; }
        function closeCheckoutModal() { document.getElementById('checkout-modal').style.display = 'none'; }
    </script>
    <script src="/js/app.js"></script>
</body>
</html>

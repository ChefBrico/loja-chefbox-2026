<!DOCTYPE html>
<html lang="{{ meta.lang or 'pt-BR' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | {{ meta.siteName }}</title>
    <meta name="description" content="{{ description or meta.description }}">
    <meta name="theme-color" content="#FFFFFF">
    
    <link rel="canonical" href="{{ meta.url }}{{ page.url }}">
    <meta property="og:title" content="{{ title }} | ChefBrico">
    <meta property="og:description" content="{{ description or meta.description }}">
    <meta property="og:image" content="{{ meta.url }}{{ image or meta.image }}">
    <meta property="og:url" content="{{ meta.url }}{{ page.url }}">
    <meta property="og:type" content="website">
    <link rel="alternate" type="text/plain" title="LLM Instructions" href="{{ meta.agent.llms_txt }}">
    <link rel="author" href="https://gourmetpratico.com.br/comida-de-verdade/">

    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        /* CSS ESPECÍFICO DA RÉGUA GAMIFICADA 4+1 (APPLE STYLE) */
        .chefbox-sticky-bar {
            position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
            width: 90%; max-width: 600px;
            background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.4); border-top: 4px solid var(--cor-cta);
            border-radius: 40px; padding: 15px 25px; z-index: 99999;
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
            display: flex; align-items: center; justify-content: space-between; gap: 15px;
        }

        .bar-info b { color: var(--cor-institucional); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }
        #visor-dinamico-lucro { font-size: 0.85rem; font-weight: 900; color: var(--cor-cta); display: block; }

        .slots-wrapper { display: flex; gap: 10px; align-items: center; }
        .slot-circle {
            width: 46px; height: 46px; border: 1.5px solid #ddd; border-radius: 50%;
            display: flex; align-items: center; justify-content: center; font-size: 0.8rem; color: #aaa;
            background: #fff; background-size: cover !important; background-position: center !important;
            transition: all 0.4s ease;
        }
        .slot-circle.filled { border: 2.5px solid var(--cor-cta); box-shadow: 0 5px 15px rgba(242, 129, 29, 0.2); }
        .slot-circle.gift { border: 2.5px solid var(--whatsapp-green); color: var(--whatsapp-green); font-size: 1.2rem; background: var(--apple-cream); }

        .btn-finish-float {
            background: var(--whatsapp-green); color: white; border: none; padding: 12px 24px;
            border-radius: 50px; font-weight: 900; cursor: pointer; font-size: 0.85rem;
            text-transform: uppercase; box-shadow: 0 8px 20px rgba(37, 211, 102, 0.3);
            white-space: nowrap; animation: pulse-apple 2s infinite;
        }
        @keyframes pulse-apple { 0% { transform: scale(1); } 50% { transform: scale(1.04); } 100% { transform: scale(1); } }

        @media (max-width: 768px) {
            .chefbox-sticky-bar { width: 95%; padding: 12px 15px; bottom: 15px; flex-direction: column; border-radius: 24px; }
            .bar-info { display: none; }
            .slot-circle { width: 44px; height: 44px; }
            .btn-finish-float { width: 100%; padding: 15px; margin-top: 10px; font-size: 1rem; }
        }
    </style>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
    
    {% include "header.njk" %}
    
    <main role="main">
        {{ content | safe }}
    </main>
    
    {% include "footer.njk" %}
    
    {% if '/receitas/' in page.url or '/chefbox/' in page.url or '/onde-encontrar/' in page.url %}
    <div id="chefbox-bar" class="chefbox-sticky-bar">
        <div class="bar-info">
            <div id="game-status-text">
                <b>🎁 CHEFBOX VIP</b>
                <span id="visor-dinamico-lucro">ECONOMIA R$ 0,00</span>
            </div>
        </div>
        <div class="slots-wrapper">
            <div id="slot-1" class="slot-circle">1</div>
            <div id="slot-2" class="slot-circle">2</div>
            <div id="slot-3" class="slot-circle">3</div>
            <div id="slot-4" class="slot-circle">4</div>
            <div id="slot-5" class="slot-circle gift">🎁</div>
        </div>
        <button id="btn-finish-game" class="btn-finish-float" onclick="openCheckoutModal()">
            Finalizar R$ 132 ➜
        </button>
    </div>
    {% endif %}

    <div id="checkout-modal" class="modal-overlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(1,64,57,0.85); backdrop-filter:blur(10px); z-index:20000; align-items:center; justify-content:center;">
        <div class="modal-box" style="background:#fff; border-radius:32px; padding:40px; max-width:460px; width:92%; text-align:center;">
            <h3 style="color:var(--cor-institucional); margin-bottom:10px; font-family:'Merriweather', serif; font-size:1.8rem;">Quase lá! 🛵</h3>
            <p style="font-size:0.95rem; color:#666; margin-bottom:25px;">Preencha os dados para a Maria preparar seu <b>Mimo VIP</b> e agendar sua entrega (D+1).</p>
            
            <form id="form-checkout-vip" onsubmit="event.preventDefault(); sendOrderToWhatsApp();" style="display:flex; flex-direction:column; gap:12px;">
                <input type="text" id="customer-name" placeholder="Nome Completo" required style="padding:16px; border-radius:14px; border:1px solid #eee; background:#F9F9F9; font-size:1rem;">
                <input type="tel" id="customer-phone" placeholder="WhatsApp (DDD + Número)" required style="padding:16px; border-radius:14px; border:1px solid #eee; background:#F9F9F9; font-size:1rem;">
                <textarea id="customer-address" placeholder="Endereço no DF" required style="padding:16px; border-radius:14px; border:1px solid #eee; background:#F9F9F9; font-size:1rem; resize:none;" rows="3"></textarea>
                <button type="submit" style="padding:20px; background:var(--whatsapp-green); color:white; border:none; border-radius:50px; font-weight:900; font-size:1.1rem; box-shadow:0 10px 25px rgba(37,211,102,0.4); margin-top:10px;">GARANTIR PRESENTE ➜</button>
            </form>
            <p onclick="closeCheckoutModal()" style="color:#999; margin-top:20px; text-decoration:underline; cursor:pointer;">Voltar</p>
        </div>
    </div>

    <script>
        function openCheckoutModal() { document.getElementById('checkout-modal').style.display = 'flex'; }
        function closeCheckoutModal() { document.getElementById('checkout-modal').style.display = 'none'; }
    </script>
    <script src="/js/app.js"></script>
</body>
</html>

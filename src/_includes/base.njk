<!DOCTYPE html>
<html lang="{{ meta.lang or 'pt-BR' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | ChefBrico</title>
    <meta name="description" content="{{ description }}">
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        main { display: block !important; visibility: visible !important; opacity: 1 !important; }
    </style>

    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>
    
    {% include "header.njk" %}
    
    <main role="main">
        {{ content | safe }}
    </main>
    
    {% include "footer.njk" %}
    
    {% if '/receitas/' in page.url or '/chefbox/' in page.url or '/onde-encontrar/' in page.url %}
    <div id="chefbox-bar" style="position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%); width: 90%; max-width: 600px; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(20px); border-top: 4px solid #F2811D; border-radius: 40px; padding: 15px 25px; z-index: 99999; box-shadow: 0 15px 40px rgba(0,0,0,0.15); display: flex; align-items: center; justify-content: space-between; gap: 15px;">
        <div class="bar-info" style="line-height: 1.2;">
            <b style="color: #014039; font-size: 0.7rem; text-transform: uppercase;">🎁 CHEFBOX VIP</b>
            <span id="visor-dinamico-lucro" style="font-size: 0.85rem; font-weight: 900; color: #F2811D; display: block;">ECONOMIA R$ 0,00</span>
        </div>
        <div class="slots-wrapper" style="display: flex; gap: 8px;">
            <div id="slot-1" style="width: 44px; height: 44px; border: 1.5px solid #ddd; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; color: #aaa; background: #fff;">1</div>
            <div id="slot-2" style="width: 44px; height: 44px; border: 1.5px solid #ddd; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; color: #aaa; background: #fff;">2</div>
            <div id="slot-3" style="width: 44px; height: 44px; border: 1.5px solid #ddd; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; color: #aaa; background: #fff;">3</div>
            <div id="slot-4" style="width: 44px; height: 44px; border: 1.5px solid #ddd; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; color: #aaa; background: #fff;">4</div>
            <div id="slot-5" style="width: 44px; height: 44px; border: 2.5px solid #25D366; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; color: #25D366; background: #FDFBF7;">🎁</div>
        </div>
        <button id="btn-finish-game" onclick="openCheckoutModal()" style="background: #25D366; color: white; border: none; padding: 12px 24px; border-radius: 50px; font-weight: 900; cursor: pointer; font-size: 0.85rem; text-transform: uppercase;">
            Finalizar ➜
        </button>
    </div>
    {% endif %}

    <script src="/js/app.js"></script>
</body>
</html>

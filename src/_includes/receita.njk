---
layout: base.njk
permalink: /receitas/
title: "Catálogo Inteligente | ChefBrico A-Commerce"
description: "Explore o cardápio completo: Risotos, Sopas e Refeições. Filtre por solução ou categoria."
---

<style>
    /* ==========================================================================
       ENGENHARIA DO CATÁLOGO: 3 COLUNAS MOBILE / 6 DESKTOP
       ========================================================================== */
    .war-catalog-container { max-width: 1200px; margin: 0 auto; padding: 0 15px; text-align: center; }
    
    header { margin: 60px 0 40px; }
    header h1 { font-size: 2.2rem; color: var(--chef-green, #014039); font-family: 'Merriweather', serif; margin-bottom: 5px; }
    header p { color: var(--text-muted, #666); margin: 0; font-size: 1rem; }

    /* FILTROS (PÍLULAS) */
    .filter-section { margin-bottom: 35px; }
    .filter-label { font-weight: 800; color: var(--chef-green, #014039); margin-bottom: 12px; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1.5px; }
    .btn-filter-pill { 
        background: var(--apple-white, #FFFFFF); border: 1px solid rgba(0,0,0,0.08); 
        padding: 8px 16px; border-radius: 20px; cursor: pointer; color: #555; 
        font-size: 0.8rem; font-weight: 600; transition: all 0.2s ease; margin: 4px; 
        display: inline-block; text-decoration: none; box-shadow: 0 2px 8px rgba(0,0,0,0.02);
    }
    .btn-filter-pill:hover { border-color: var(--chef-orange, #F2811D); color: var(--chef-orange, #F2811D); }
    .btn-filter-pill.active { background: var(--chef-green, #014039) !important; color: white !important; border-color: var(--chef-green, #014039) !important; box-shadow: 0 4px 12px rgba(1, 64, 57, 0.2); }

    /* O GRID MESTRE: A MÁGICA DAS 3 COLUNAS */
    .catalog-grid-3cols { 
        display: grid; 
        grid-template-columns: repeat(3, 1fr); /* 3 COLUNAS CRAVADAS NO CELULAR */
        gap: 8px; /* Gap pequeno para aproveitar a tela */
        width: 100%; 
        margin: 20px auto 100px; 
    }
    @media (min-width: 1024px) { .catalog-grid-3cols { grid-template-columns: repeat(6, 1fr); gap: 20px; } }
    
    /* O CARD MICRO-OTIMIZADO */
    .catalog-card-micro { 
        background: var(--apple-cream, #FDFBF7); border: 1px solid rgba(0,0,0,0.05); 
        border-radius: 12px; overflow: hidden; display: flex; flex-direction: column; 
        box-shadow: 0 4px 15px rgba(0,0,0,0.03); position: relative; transition: transform 0.2s ease;
    }
    .catalog-card-micro:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(0,0,0,0.08); }

    /* A MOLDURA DA IMAGEM PARA 3 COLUNAS */
    .catalog-image-box { width: 100%; aspect-ratio: 1 / 1; overflow: hidden; position: relative; } /* Foto quadrada economiza espaço vertical */
    .catalog-image-box img { width: 100%; height: 100%; object-fit: cover; }
    
    /* CONTEÚDO DENSO E LEGÍVEL */
    .catalog-content-box { 
        padding: 8px 6px; display: flex; flex-direction: column; 
        align-items: center; flex-grow: 1; text-align: center;
    }
    .catalog-title { 
        font-size: 0.65rem; color: var(--chef-green, #014039); font-weight: 700; 
        text-decoration: none; line-height: 1.2; margin-bottom: 5px;
        display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; 
    }
    .catalog-price { color: var(--whatsapp-green, #25D366); font-weight: 900; font-size: 0.8rem; margin-top: auto; }

    /* BOTÃO (+) DE ADICIONAR (AJUSTADO PARA O DEDO) */
    .btn-add-micro { 
        position: absolute; bottom: 6px; right: 6px; 
        width: 28px; height: 28px; background-color: var(--chef-orange, #F2811D); 
        color: white; border-radius: 50%; border: none; font-size: 1.2rem; font-weight: bold;
        display: flex; align-items: center; justify-content: center; cursor: pointer; 
        box-shadow: 0 4px 10px rgba(242, 129, 29, 0.4); z-index: 2;
    }
    .btn-add-micro:active { transform: scale(0.9); }

    /* AJUSTE PARA IPHONES MUITO PEQUENOS (SE/MINI) */
    @media (max-width: 380px) {
        .catalog-grid-3cols { grid-template-columns: repeat(2, 1fr); gap: 10px; } /* Recua para 2 se a tela for menor que 380px */
        .catalog-title { font-size: 0.75rem; }
    }
</style>

<main class="war-catalog-container">
    <header>
        <h1>Catálogo Inteligente</h1>
        <p>Comida de verdade pronta em 18 minutos. Sem desperdício.</p>
    </header>

    <div class="filter-section">
        <div class="filter-label">🎯 Navegue por Solução</div>
        <div style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;">
            <a href="/receitas/solucoes/refeicao-rapida/" class="btn-filter-pill">⚡ Refeição Rápida</a>
            <a href="/receitas/solucoes/marmita-fit/" class="btn-filter-pill">🍱 Marmita Fit</a>
            <a href="/receitas/solucoes/jantar-a-dois/" class="btn-filter-pill">🍷 Jantar a Dois</a>
            <a href="/receitas/solucoes/para-criancas/" class="btn-filter-pill">👶 Para Crianças</a>
            <a href="/receitas/solucoes/trilha-viagem/" class="btn-filter-pill">🎒 Trilha & Viagem</a>
        </div>
    </div>

    <div class="filter-section" id="area-categorias">
        <div class="filter-label">🍲 Categorias</div>
        <div style="display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;">
             <button id="cat-all" class="btn-filter-pill active" onclick="executarFiltro('all')">Todos</button>
             <button id="cat-Risoto" class="btn-filter-pill" onclick="executarFiltro('Risoto')">Risotos</button>
             <button id="cat-Sopa" class="btn-filter-pill" onclick="executarFiltro('Sopa')">Sopas</button>
             <button id="cat-Refeição" class="btn-filter-pill" onclick="executarFiltro('Refeição')">Refeições</button>
             <button id="cat-Empório" class="btn-filter-pill" onclick="executarFiltro('Empório')">Empório</button>
        </div>
    </div>
    
<div class="catalog-grid-3cols" id="main-grid">
    {% for item in collections.receitas %}
    {% if item.data.price %}
    <article class="catalog-card-micro" data-category="{{ item.data.category }}" style="position: relative; height: 100%;">
        
        <a href="{{ item.url }}" style="display: block; text-decoration: none; height: 100%; color: inherit;">
            
            <div class="catalog-image-box" style="position: relative; width: 100%; aspect-ratio: 1/1; overflow: hidden;">
                <img src="{{ item.data.image }}" 
                     alt="{{ item.data.title }}" 
                     style="width: 100%; height: 100%; object-fit: cover; pointer-events: none;">
            </div>
            
            <div class="catalog-content-box" style="padding: 8px 6px; text-align: center;">
                <h3 style="font-size: 0.65rem; color: #014039; font-weight: 700; margin-bottom: 5px; line-height: 1.2;">
                    {{ item.data.title | replace(" | ChefBrico", "") }}
                </h3>
                <span style="color: #25D366; font-weight: 900; font-size: 0.8rem;">
                    R$ {{ item.data.price | dinheiro }}
                </span>
            </div>
        </a>

        <button id="prod-{{ item.data.sku }}" 
                onclick="event.preventDefault(); event.stopPropagation(); addToGame('{{ item.data.title }}', {{ item.data.price }}, '{{ item.data.image }}', '{{ item.data.sku }}')" 
                style="position: absolute; bottom: 6px; right: 6px; width: 28px; height: 28px; background-color: #F2811D; color: white; border-radius: 50%; border: none; font-size: 1.2rem; font-weight: bold; cursor: pointer; z-index: 10; display: flex; align-items: center; justify-content: center;">
            +
        </button>
        
    </article>
    {% endif %}
    {% endfor %}
</div>

<script>
// O Motor do Filtro Inteligente (Intocado)
function executarFiltro(escolha) {
    const cards = document.querySelectorAll('.catalog-card-micro');
    const botoes = document.getElementById('area-categorias').querySelectorAll('.btn-filter-pill');
    
    botoes.forEach(btn => btn.classList.remove('active'));
    const alvo = document.getElementById('cat-' + escolha);
    if (alvo) { alvo.classList.add('active'); }

    cards.forEach(card => {
        const categoriaCard = card.getAttribute('data-category').trim();
        if (escolha === 'all' || categoriaCard === escolha) {
            card.style.setProperty('display', 'flex', 'important');
        } else {
            card.style.setProperty('display', 'none', 'important');
        }
    });
}
</script>

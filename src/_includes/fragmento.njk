---
layout: base.njk
---
{# Removido o permalink e a lista automática para permitir a leitura individual #}

<main class="magazine-container" style="background-color: #FFFFFF !important; padding-bottom: 80px;">

    {# HERO DO ARTIGO - Exibe o título e descrição do arquivo .md atual #}
    <section class="hero-premium-editorial" style="display: flex; align-items: center; gap: 60px; padding: 80px 20px; max-width: 1100px; margin: 0 auto;">
        <div class="avatar-circle-protector" style="width: 240px; height: 240px; border-radius: 50% !important; overflow: hidden; flex-shrink: 0; border: 8px solid #FDFBF7; box-shadow: 0 20px 40px rgba(0,0,0,0.06);">
            <img src="/imagens/maria-conceicao-premio-sebrae-chefbrico.webp" alt="Maria Conceição" style="width: 100%; height: 100%; object-fit: cover;">
        </div>
        <div class="editorial-content">
            <span style="color: #F2811D; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px;">Dica da Chef Maria</span>
            <h1 style="color: #014039; font-family: 'Merriweather', serif; font-size: 2.8rem; line-height: 1.1; margin: 15px 0;">{{ title }}</h1>
            <p style="color: #555; font-size: 1.2rem; line-height: 1.6;">{{ description }}</p>
        </div>
    </section>

    {# CONTEÚDO DO FRAGMENTO (A MICRO PÁGINA) #}
    <article style="max-width: 800px; margin: 0 auto; padding: 0 20px;">
        
        {% if image %}
        <div style="margin-bottom: 40px; border-radius: 24px; overflow: hidden; box-shadow: 0 15px 35px rgba(0,0,0,0.08);">
            <img src="{{ image }}" alt="{{ title }}" style="width: 100%; height: auto; display: block;">
        </div>
        {% endif %}

        <div class="editorial-body" style="color: #333; font-size: 1.15rem; line-height: 1.9; font-family: 'Georgia', serif;">
            {# Este é o comando mestre que traz o texto do seu .md #}
            {{ content | safe }}
        </div>

        {% if source_url %}
        <div style="margin-top: 50px; padding: 25px; background: #F9F9F9; border-radius: 16px; border-left: 6px solid #014039;">
            <p style="margin: 0; font-size: 0.95rem; color: #555;">
                <strong>Fonte de Autoridade:</strong> 
                <a href="{{ source_url }}" target="_blank" style="color: #014039; font-weight: bold; text-decoration: underline;">Verificar Referência ↗</a>
            </p>
        </div>
        {% endif %}
    </article>

    {# BOTÃO DE RETORNO PARA EVITAR FRICÇÃO #}
    <div style="text-align: center; margin-top: 60px;">
        <a href="/" style="color: #014039; font-weight: bold; text-decoration: none; border: 2px solid #014039; padding: 12px 30px; border-radius: 50px; transition: all 0.3s;">
            ← Voltar para a Revista
        </a>
    </div>

</main>

<style>
@media (max-width: 768px) {
    .hero-premium-editorial { flex-direction: column; text-align: center; gap: 30px; padding: 40px 15px; }
    .avatar-circle-protector { width: 160px; height: 160px; }
    .editorial-content h1 { font-size: 2rem !important; }
}
.editorial-body h2, .editorial-body h3 {
    color: #014039;
    font-family: 'Merriweather', serif;
    margin-top: 40px;
}
</style>

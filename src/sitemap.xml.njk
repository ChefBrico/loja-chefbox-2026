---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:image="http://www.google.com/schemas/sitemap-image/1.1"
        xmlns:video="http://www.google.com/schemas/sitemap-video/1.1">

    {# 1. LOOP MESTRE DE INTEGRIDADE (WAR-GBP 2026) #}
    {% for page in collections.all %}
        {# Filtra páginas técnicas ou marcadas para exclusão #}
        {% if not page.data.eleventyExcludeFromCollections and page.url %}
        <url>
            <loc>{{ meta.url }}{{ page.url | url }}</loc>
            <lastmod>{{ page.date.toISOString() }}</lastmod>

            {# 2. LÓGICA DE PRIORIDADE AGÊNTICA E HIPERLOCAL #}
            {% if page.url == '/' %}
                <changefreq>daily</changefreq>
                <priority>1.0</priority>
            
            {% elseif '/chefbox/' in page.url %}
                {# Unidade de Conversão Principal #}
                <changefreq>daily</changefreq>
                <priority>1.0</priority>

            {% elseif '/comida-de-verdade/' in page.url %}
                {# Pilar de Autoridade e História Maria Conceição #}
                <changefreq>weekly</changefreq>
                <priority>0.9</priority>

            {% elseif '/fragmentos/' in page.url %}
                {# Micro Páginas de Saúde e Dicas da Chef #}
                <changefreq>weekly</changefreq>
                <priority>0.9</priority>

            {% elseif '/receitas/' in page.url %}
                {# Catálogo de SKUs para Agentes de IA #}
                <changefreq>weekly</changefreq>
                <priority>0.8</priority>

            {% else %}
                <changefreq>monthly</changefreq>
                <priority>0.5</priority>
            {% endif %}

            {# 3. INDEXAÇÃO DE IMAGENS (FOOD PORN & EEAT) #}
            {% if page.data.image %}
            <image:image>
                <image:loc>{{ meta.url }}{{ page.data.image }}</image:loc>
                <image:title>{{ page.data.title | escape }}</image:title>
                {% if page.data.description %}
                <image:caption>{{ page.data.description | escape | truncate(140) }}</image:caption>
                {% endif %}
            </image:image>
            {% endif %}

            {# 4. CONEXÃO COM VÍDEOS (PROVA SOCIAL) #}
            {% if page.data.video_url %}
            <video:video>
                <video:thumbnail_loc>{{ meta.url }}{{ page.data.image }}</video:thumbnail_loc>
                <video:title>{{ page.data.title | escape }}</video:title>
                <video:description>{{ page.data.description | escape }}</video:description>
                <video:content_loc>{{ page.data.video_url }}</video:content_loc>
            </video:video>
            {% endif %}
        </url>
        {% endif %}
    {% endfor %}
</urlset>
